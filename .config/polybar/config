[colors]
background = #aa282828
foreground = #ebdbb2

[bar/bsp]
width = 100%
height = 30

background = ${colors.background}
foreground = ${colors.foreground}

padding = 2
module-margin = 2

font-0 = Noto Sans CJK SC:weight=Medium:size=13;2
font-1 = Font Awesome 5 Free Solid:style=Regular:size=13;3

modules-left = bspwm
modules-center = title
modules-right = netspeed backlight pulseaudio wifi battery date

tray-position = right

fixed-center = false
wm-restack = bspwm

[module/bspwm]
type = internal/bspwm

label-focused = %index%^
label-focused-underline= ${colors.foreground}
label-focused-padding = 2

label-occupied = %index%
label-occupied-padding = 2

label-urgent = %index%!
label-urgent-padding = 2

label-empty = %index%
label-empty-foreground = #7fffffff
label-empty-padding = 2

[module/title]
type = internal/xwindow
format = <label>
label = %title%
label-maxlen = 60

[module/date]
type = internal/date
date = %a %b %d
time = %H:%M
label = %date%  %time%

[module/netspeed]
type = internal/network
interface = wlan0
label-connected =  %downspeed%   %upspeed%
format-connected= <label-connected>

[module/backlight]
type = internal/backlight
card = intel_backlight
format = <label>
label =  %percentage%%

[module/pulseaudio]
type = internal/pulseaudio
format-volume = <label-volume>
label-volume =  %percentage%%
label-muted =  muted

[module/wifi]
type = internal/network
interface = wlan0
format-connected =  <label-connected>
label-connected = %essid%
format-disconnected =  <label-disconnected>
label-disconnected = Disconnected

[module/battery]
type = internal/battery
battery = BAT0
full-at = 99
format-charging = <label-charging>
format-discharging = <label-discharging>
label-full =  %percentage%%
label-charging =  %percentage%%
label-discharging =  %percentage%%

[global/wm]
margin-top = 0
margin-bottom = 0

; vim:ft=dosini
